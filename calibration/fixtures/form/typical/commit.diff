+def test_score_batch_length():
+    diffs = ["diff --git a/x b/x\n--- a/x\n+++ b/x\n@@ -1 +1 @@\n-old\n+new"] * 3
+    results = score_batch(diffs, "grid")
+    assert len(results) == 3
