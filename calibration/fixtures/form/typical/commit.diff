diff --git a/commitmatrix/scorer.py b/commitmatrix/scorer.py
index aabbcc..ddeeff 100644
--- a/commitmatrix/scorer.py
+++ b/commitmatrix/scorer.py
@@ -31,3 +31,12 @@ def score_commit(diff: str, rubric: str) -> RubricResult:
     ...
+
+
+def score_batch(diffs: list[str], rubric: str) -> list[RubricResult]:
+    """Score a list of diffs against the same rubric.
+    
+    Args:
+        diffs: List of unified diff strings
+        rubric: Rubric name (e.g. 'grid', 'plan')
+    Returns:
+        List of RubricResult in input order
+    """
+    return [score_commit(d, rubric) for d in diffs]
